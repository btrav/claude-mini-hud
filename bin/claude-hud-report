#!/usr/bin/env bash
# claude-mini-hud report
# Prints a usage summary from ~/.claude/usage-log.jsonl
#
# Usage: claude-hud-report [--today|--week|--month|--all]

LOG="$HOME/.claude/usage-log.jsonl"

# ── Parse flags ───────────────────────────────────────────────────────────────
period="week"
for arg in "$@"; do
  case "$arg" in
    --today) period="today" ;;
    --week)  period="week"  ;;
    --month) period="month" ;;
    --all)   period="all"   ;;
    -h|--help)
      echo "Usage: claude-hud-report [--today|--week|--month|--all]"
      echo "  --today   Last 24 hours"
      echo "  --week    Last 7 days (default)"
      echo "  --month   Last 30 days"
      echo "  --all     All time"
      exit 0
      ;;
  esac
done

# ── Check log exists ──────────────────────────────────────────────────────────
if [[ ! -f "$LOG" ]]; then
  echo "No usage log at $LOG"
  echo "Log data is recorded at the end of each Claude Code session."
  exit 0
fi

# ── Calculate time range ──────────────────────────────────────────────────────
now=$(date +%s)
case "$period" in
  today) since=$(( now - 86400 ))      ; label="Last 24 hours" ;;
  week)  since=$(( now - 7 * 86400 ))  ; label="Last 7 days"   ;;
  month) since=$(( now - 30 * 86400 )) ; label="Last 30 days"  ;;
  all)   since=0                        ; label="All time"      ;;
esac

# ── ANSI ──────────────────────────────────────────────────────────────────────
BOLD='\033[1m'; DIM='\033[2m'; GREEN='\033[32m'; RESET='\033[0m'
SEP="${DIM}─────────────────────────────${RESET}"

# ── Aggregate ─────────────────────────────────────────────────────────────────
# The Stop hook fires after every Claude response, not just once per session,
# and writes cumulative tokens each time. Take per-session max before summing
# so a 200-row session doesn't get counted 200x.
result=$(
  jq -rcs \
    --argjson since "$since" \
    '
      def fmt_dur(ms):
        (ms / 60000 | floor) as $m |
        if   $m <= 0  then "<1m"
        elif $m >= 60 then "\($m/60|floor)h \($m%60)m"
        else "\($m)m" end;
      map(select(.ts > $since)) |
      if length == 0 then
        "EMPTY"
      else
        group_by(.session_id) |
        map({
          tokens_in:   (map(.tokens_in   // 0) | max),
          tokens_out:  (map(.tokens_out  // 0) | max),
          peak_ctx:    (map(.ctx_pct     // 0) | max),
          duration_ms: (map(.duration_ms // 0) | max),
          model:       ([.[] | .model // "" | select(. != "")] | last // "unknown")
        }) |
        {
          sessions:    length,
          tokens_in:   (map(.tokens_in)   | add),
          tokens_out:  (map(.tokens_out)  | add),
          peak_ctx:    (map(.peak_ctx)    | max),
          total_ms:    (map(.duration_ms) | add),
          models:      ([.[] | .model | select(. != "" and . != "unknown")]
                        | if length == 0 then ["unknown"] else . end
                        | group_by(.) | map("\(.[0]) (\(length))") | join(", "))
        } |
        [
          "Sessions:   \(.sessions)",
          "Tokens in:  \(.tokens_in)",
          "Tokens out: \(.tokens_out)",
          "Peak ctx:   \(.peak_ctx)%",
          "Total time: \(fmt_dur(.total_ms))",
          "Models:     \(.models)"
        ] | join("\n")
      end
    ' "$LOG" 2>/dev/null
)

# ── Output ─────────────────────────────────────────────────────────────────────
printf "\n${BOLD}✦CC✦  claude-mini-hud · %s${RESET}\n" "$label"
printf "%b\n" "$SEP"

if [[ "$result" == "EMPTY" ]]; then
  printf "No sessions recorded for this period.\n"
else
  while IFS= read -r line; do
    printf "%s\n" "$line"
  done <<< "$result"
fi

printf "%b\n\n" "$SEP"
